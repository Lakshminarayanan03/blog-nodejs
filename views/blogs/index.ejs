<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head.ejs') %>
<body>
    <%- include('../partials/nav.ejs') %>
   
    <div class="content-wrapper">
        <h1 class="main-title">Welcome to My Blog</h1>
        <p class="description">This is the home page of the blog. Explore our content and learn more about us.</p>

        <div class="blog-section">
            <h2 class="section-title">Latest Blog Posts</h2>
            <div id="blog-posts">
                
                <% if (blogs.length > 0) { %>
                    <% blogs.forEach(blog => { %>
                        <div class="blog-card">
                            <a class="single" href="/blogs/<%= blog._id %>">
                            <h3 class="blog-title"><%= blog.title %></h3>
                            <p class="blog-snippet"><%= blog.body %></p>
                            </a>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="no-blogs">No blog posts available yet.</p>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('../partials/footer.ejs') %>
</body>
</html>
